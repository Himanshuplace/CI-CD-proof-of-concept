{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "gnexlayer-api-gateway",
  "port": 8080,
  "timeout": "10000ms",
  "cache_ttl": "0s",

  "extra_config": {
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },

    "telemetry/metrics": {
      "collection_time": "60s",
      "listen_address": ":8090"
    },

    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Content-Type", "Authorization"],
      "expose_headers": ["Content-Length"],
      "max_age": "12h"
    }
  },

  "endpoints": [
    {
      "__comment": "Health check — HAProxy uses this to verify KrakenD is alive.",
      "endpoint": "/healthz",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "host": ["http://go-service:8080"],
          "url_pattern": "/healthz",
          "encoding": "json"
        }
      ]
    },

    {
      "__comment": "List users — GET /api/v1/users",
      "endpoint": "/api/v1/users",
      "method": "GET",
      "output_encoding": "json",

      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 100,
          "client_max_rate": 20,
          "strategy": "ip",
          "every": "1s"
        }
      },

      "backend": [
        {
          "host": ["http://go-service:8080"],
          "url_pattern": "/api/v1/users",
          "encoding": "json",
          "is_collection": true
        }
      ]
    },

    {
      "__comment": "Create user — POST /api/v1/users",
      "endpoint": "/api/v1/users",
      "method": "POST",
      "output_encoding": "json",
      "backend": [
        {
          "host": ["http://go-service:8080"],
          "url_pattern": "/api/v1/users",
          "encoding": "json"
        }
      ]
    },

    {
      "__comment": "Get user by ID — GET /api/v1/users/{id}",
      "endpoint": "/api/v1/users/{id}",
      "method": "GET",
      "output_encoding": "json",
      "backend": [
        {
          "host": ["http://go-service:8080"],
          "url_pattern": "/api/v1/users/{id}",
          "encoding": "json"
        }
      ]
    }
  ]
}
